---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — No encontrado | Nexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main style="display:flex;align-items:center;justify-content:center;min-height:100vh;text-align:center;padding:2rem;">
      <div>
        <h1 style="font-size:clamp(4rem,12vw,10rem);font-weight:900;background:linear-gradient(135deg,#7c3aed,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:1rem;">404</h1>
        <p style="color:#94a3b8;font-size:1.2rem;margin-bottom:2rem;">Esta página no existe. El futuro está en otra parte.</p>
        <a href="/" style="display:inline-block;padding:1rem 2.5rem;border-radius:100px;font-weight:600;background:linear-gradient(135deg,#7c3aed,#06b6d4);color:#fff;text-decoration:none;box-shadow:0 0 40px rgba(124,58,237,0.3);">Volver al inicio</a>
      </div>
    </main>
  </body>
</html>
